      "paymentProcessing": {
        "title": "Pagamento reconhecido",
        "html": "<div class=\"order-status-html order-status-html--warning\" style=\"text-align: center;\"><div class=\"order-status-html__content\"><h3 class=\"order-status-html__title\"><span aria-hidden=\"true\">☕</span> Pagamento reconhecido</h3><p class=\"order-status-html__text\">Recebemos seu pagamento e já estamos processando o envio das cripto para a carteira informada.</p><p class=\"order-status-html__text\">Esse processo pode levar até 5 minutos. Esta página será atualizada automaticamente.</p></div></div>"
      },
      "orderConcluded": {
        "title": "Pedido concluído",
        "html": "<div class=\"order-status-html order-status-html--success\" style=\"text-align: center;\"><div class=\"order-status-html__content\"><h3 class=\"order-status-html__title\"><span aria-hidden=\"true\">✅</span> Pedido concluído com sucesso</h3><p class=\"order-status-html__text\">Tudo certo. As criptos foram enviadas para a carteira informada.</p><p class=\"order-status-html__text\">Obrigado por utilizar a Infinite Ativos Virtuais.</p><div class=\"order-status-html__actions\" style=\"margin-top: 20px; display: flex; gap: 12px; justify-content: center; align-items: center; flex-wrap: wrap;\"><button class=\"order-status-html__button order-status-html__button--primary\" type=\"button\" onclick=\"window.location.href='/'\">Menu Principal</button></div></div></div>",
        "html_sell": "<div class=\"order-status-html order-status-html--success\" style=\"text-align: center;\"><div class=\"order-status-html__content\"><h3 class=\"order-status-html__title\"><span aria-hidden=\"true\">✅</span> Pedido concluído com sucesso</h3><p class=\"order-status-html__text\">Tudo certo. O valor foi depositado para o PIX informado.</p><p class=\"order-status-html__text\">Obrigado por utilizar a Infinite Ativos Virtuais.</p><div class=\"order-status-html__actions\" style=\"margin-top: 20px; display: flex; gap: 12px; justify-content: center; align-items: center; flex-wrap: wrap;\"><button class=\"order-status-html__button order-status-html__button--primary\" type=\"button\" onclick=\"window.location.href='/'\">Menu Principal</button></div></div></div>"
      },
      "paymentUpdateTimeout": {
        "title": "Pagamento expirado",
        "html": "<div class=\"order-status-html order-status-html--danger\" style=\"text-align: center;\"><div class=\"order-status-html__content\"><h3 class=\"order-status-html__title\"><span aria-hidden=\"true\">💔</span> Pagamento não processado</h3><p class=\"order-status-html__text\">Não conseguimos processar a confirmação do pagamento no prazo esperado.</p><p class=\"order-status-html__text\">Se você realizou o pagamento ou acredita que isso é um erro, fale com o suporte.</p><div class=\"order-status-html__actions\" style=\"margin-top: 20px; display: flex; gap: 12px; justify-content: center; align-items: center; flex-wrap: wrap;\"><button class=\"order-status-html__button order-status-html__button--primary\" type=\"button\" onclick=\"window.location.href='/'\">Menu Principal</button><button class=\"order-status-html__button order-status-html__button--secondary\" type=\"button\" onclick=\"window.location.href='mailto:{supportEmail}'\">Falar com suporte</button></div></div></div>"
      },
      "orderUpdateTimeout": {
        "title": "Pedido atrasado",
        "html": "<div class=\"order-status-html order-status-html--danger\" style=\"text-align: center;\"><div class=\"order-status-html__content\"><h3 class=\"order-status-html__title\"><span aria-hidden=\"true\">💔</span> Processamento atrasado</h3><p class=\"order-status-html__text\">Não conseguimos concluir o processamento do pedido no prazo esperado.</p><p class=\"order-status-html__text\">Se você acredita que isso é um erro, fale com o suporte.</p><div class=\"order-status-html__actions\" style=\"margin-top: 20px; display: flex; gap: 12px; justify-content: center; align-items: center; flex-wrap: wrap;\"><button class=\"order-status-html__button order-status-html__button--primary\" type=\"button\" onclick=\"window.location.href='/'\">Menu Principal</button><button class=\"order-status-html__button order-status-html__button--secondary\" type=\"button\" onclick=\"window.location.href='mailto:{supportEmail}'\">Falar com suporte</button></div></div></div>"
