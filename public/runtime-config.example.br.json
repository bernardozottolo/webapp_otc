      "paymentTimeout": {
        "title": "Pagamento expirado",
        "html": "<div class=\"order-status-html order-status-html--danger\" style=\"text-align: center;\"><div class=\"order-status-html__content\"><h3 class=\"order-status-html__title\"><span aria-hidden=\"true\">❌</span> Prazo de pagamento encerrado</h3><p class=\"order-status-html__text\">Não identificamos o pagamento dentro do prazo, então este pedido foi cancelado automaticamente.</p><p class=\"order-status-html__text\">Para continuar, volte ao Menu Principal e gere um novo pedido.</p><div class=\"order-status-html__actions\" style=\"margin-top: 20px; display: flex; gap: 12px; justify-content: center; align-items: center; flex-wrap: wrap;\"><button class=\"order-status-html__button order-status-html__button--primary\" type=\"button\" onclick=\"window.location.href='/'\">Menu Principal</button><button class=\"order-status-html__button order-status-html__button--secondary\" type=\"button\" onclick=\"window.location.href='mailto:{supportEmail}'\">Falar com suporte</button></div></div></div>"
