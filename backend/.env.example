LOG_LEVEL=INFO
DIDIT_API_KEY=
DIDIT_API_BASE_URL=https://verification.didit.me
DIDIT_CALLBACK_URL=
DIDIT_WAITING_URL=
DIDIT_DOCUMENT_VERIFICATION_WORKFLOW_ID=
DIDIT_BIOMETRIC_VALIDATION_WORKFLOW_ID=
FRONTEND_DIST_DIR=dist
PROXY_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
OTC_UPSTREAM_API_BASE_URL=
# Ex.: https://infiniteativosvirtuais.tec.br — activa POST /otc/get_pricing, /otc/pre_order_validation, /otc/create_order, /otc/counterparty_kyc, /otc/get_available_withdraw_networks, /otc/check_wallet_risk e demais rotas OTC suportadas no FastAPI
CLIENTS_DATABASE_API_BASE_URL=
# Ex.: https://origin-internal.com.br — activa POST /webhook/clients_database no FastAPI
# URL que a API OTC deve chamar quando houver atualização de status da ordem.
# Normalmente aponta para um webhook n8n ou para um endpoint do próprio backend.
ORDER_UPDATE_WEBHOOK_URL=
ORDER_UPDATES_TTL_MS=3600000
BIOMETRIC_RATE_LIMIT_PER_IP_PER_DAY=3
BIOMETRIC_RATE_LIMIT_FILE=.runtime/biometric_rate_limits.json
HTTP_LOG_REQUEST_BODY_MAX_CHARS=8192
HTTP_LOG_RESPONSE_BODY_MAX_CHARS=8192
HTTP_LOG_RESPONSE_BUFFER_MAX_BYTES=524288
