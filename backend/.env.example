LOG_LEVEL=INFO
DIDIT_API_KEY=
DIDIT_API_BASE_URL=https://verification.didit.me
DIDIT_CALLBACK_URL=
DIDIT_WAITING_URL=
DIDIT_DOCUMENT_VERIFICATION_WORKFLOW_ID=
DIDIT_BIOMETRIC_VALIDATION_WORKFLOW_ID=
FRONTEND_DIST_DIR=dist
PROXY_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
OTC_UPSTREAM_API_BASE_URL=
# Ex.: https://infiniteativosvirtuais.tec.br — activa POST /otc/get_pricing, /otc/pre_order_validation, /otc/create_order, /otc/counterparty_kyc, /otc/get_available_withdraw_networks, /otc/check_wallet_risk e demais rotas OTC suportadas no FastAPI
CLIENTS_DATABASE_API_BASE_URL=
# Ex.: https://origin-internal.com.br — activa POST /webhook/clients_database no FastAPI
# URL que a API OTC deve chamar quando houver atualização de status da ordem.
# Normalmente aponta para um webhook n8n ou para um endpoint do próprio backend.
ORDER_UPDATE_WEBHOOK_URL=
ORDER_UPDATES_TTL_MS=3600000
BIOMETRIC_RATE_LIMIT_PER_IP_PER_DAY=3
BIOMETRIC_RATE_LIMIT_FILE=.runtime/biometric_rate_limits.json
SEND_EMAIL_URL=
REDIS_URL=redis://localhost:6379/0
# Fila de biometrias Didit em revisão (TTL e intervalo de poll; mensagens vêm do runtime-config biometryReview)
BIOMETRY_PENDING_TTL_HOURS=48
BIOMETRY_PENDING_POLL_INTERVAL_SECONDS=300
RATE_LIMIT_ENABLED=true
IP_BLACKLIST_ENABLED=true
AUDIT_LOG_ENABLED=true
RATE_LIMIT_DEFAULT_REQUESTS=120
RATE_LIMIT_DEFAULT_WINDOW_SECONDS=60
RATE_LIMIT_SEND_EMAIL_REQUESTS=5
RATE_LIMIT_SEND_EMAIL_WINDOW_SECONDS=300
RATE_LIMIT_DIDIT_SESSION_REQUESTS=10
RATE_LIMIT_DIDIT_SESSION_WINDOW_SECONDS=300
RATE_LIMIT_CREATE_ORDER_REQUESTS=10
RATE_LIMIT_CREATE_ORDER_WINDOW_SECONDS=300
RATE_LIMIT_GET_PRICING_REQUESTS=120
RATE_LIMIT_GET_PRICING_WINDOW_SECONDS=60
RATE_LIMIT_VERIFY_OTP_REQUESTS=10
RATE_LIMIT_VERIFY_OTP_WINDOW_SECONDS=300
IP_AUTO_BLOCK_ENABLED=true
IP_AUTO_BLOCK_THRESHOLD=30
IP_AUTO_BLOCK_WINDOW_SECONDS=300
IP_AUTO_BLOCK_TTL_SECONDS=3600
OTP_TTL_SECONDS=600
AUDIT_LOG_DIR=storage/logs
AUDIT_LOG_TIMEZONE=America/Sao_Paulo
AUDIT_REDIS_QUEUE_KEY=audit:queue
AUDIT_WORKER_BLOCK_SECONDS=5
ADMIN_SECURITY_TOKEN=
ORDER_NOTIFICATION_ENABLED=false
ORDER_NOTIFICATION_URL=
ORDER_NOTIFICATION_TIMEOUT_SECONDS=10
ORDER_NOTIFICATION_MAX_BODY_CHARS=100000
ORDER_NOTIFICATION_STATUSES=payment_confirmed,completed,concluded,cancelled,reproved,payment_reproved,failed,expired,timeout,payment_timeout,order_update_timeout
# Espelha backend.companyKey / backend.platform de public/runtime-config.local.json (notificações + send-email)
BACKEND_COMPANY_KEY=
BACKEND_PLATFORM=
RUNTIME_CONFIG_PATH=
# Legado (usado só se BACKEND_COMPANY_KEY e runtime-config estiverem vazios)
ORDER_NOTIFICATION_COMPANY_KEY=infinite
ORDER_NOTIFICATION_PLATFORM=webapp
ORDER_NOTIFICATION_DEDUP_TTL_SECONDS=300
ORDER_NOTIFICATION_LOCAL_PAYMENT_TIMEOUT_MS=1800000
ORDER_NOTIFICATION_LOCAL_ORDER_UPDATE_TIMEOUT_MS=300000
HTTP_LOG_REQUEST_BODY_MAX_CHARS=8192
HTTP_LOG_RESPONSE_BODY_MAX_CHARS=8192
HTTP_LOG_RESPONSE_BUFFER_MAX_BYTES=524288
