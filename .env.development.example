# Dev proxy for OTC API (avoid browser CORS). Copy to `.env.development` and adjust target.
VITE_PRICING_PROXY_TARGET=
# Example: VITE_PRICING_PROXY_TARGET=https://infiniteativosvirtuais.tec.br
DIDIT_API_KEY=
OTC_UPSTREAM_API_BASE_URL=
# Example: OTC_UPSTREAM_API_BASE_URL=https://infiniteativosvirtuais.tec.br
CLIENTS_DATABASE_API_BASE_URL=
# Example: CLIENTS_DATABASE_API_BASE_URL=https://origin-internal.com.br

# Prefix for same-origin OTC URLs when quoteBaseUrl is "". Vite proxies /api -> upstream path without /api.
VITE_OTC_DEV_PREFIX=/api
