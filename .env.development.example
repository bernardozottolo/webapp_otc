# Dev proxy for OTC API (avoid browser CORS). Copy to `.env.development` and adjust target.
VITE_PRICING_PROXY_TARGET=
# Example: VITE_PRICING_PROXY_TARGET=https://infiniteativosvirtuais.tec.br

# API key usada pelo backend para autenticar chamadas na Didit.
# Nunca deve ir para o frontend nem para arquivos versionados com valor real.
DIDIT_API_KEY=

# URL pública do seu backend que a Didit chamará quando houver atualização/resultado da sessão.
# Normalmente é um endpoint de webhook acessível pela internet.
DIDIT_CALLBACK_URL=

# URL usada como referência de espera/retorno durante o fluxo da sessão Didit.
# Pode apontar para um endpoint ou página controlada pela sua aplicação.
DIDIT_WAITING_URL=

# ID do workflow da Didit usado para verificação de documento/KYC.
# Esse valor vem do painel/configuração da Didit.
DIDIT_DOCUMENT_VERIFICATION_WORKFLOW_ID=

# ID do workflow da Didit usado para validação biométrica.
# Esse valor também vem do painel/configuração da Didit.
DIDIT_BIOMETRIC_VALIDATION_WORKFLOW_ID=

# URL base da API OTC externa que o backend usa como upstream.
OTC_UPSTREAM_API_BASE_URL=
# Example: OTC_UPSTREAM_API_BASE_URL=https://infiniteativosvirtuais.tec.br

# URL base da API/base de clientes externa.
CLIENTS_DATABASE_API_BASE_URL=
# Example: CLIENTS_DATABASE_API_BASE_URL=https://origin-internal.com.br

# Prefix for same-origin OTC URLs when quoteBaseUrl is "". Vite proxies /api -> upstream path without /api.
VITE_OTC_DEV_PREFIX=/api

# URL interna usada pelo backend para disparar o webhook de envio de e-mail/OTP.
# Exemplo: endpoint do n8n que envia o código de verificação por e-mail.
SEND_EMAIL_URL=